# Supabase project credentials — copy this file to .env and fill in real values.
# The anon/publishable key is safe to expose client-side (it's protected by RLS).
# DO NOT put service_role here — it bypasses RLS and must stay server-side only.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
